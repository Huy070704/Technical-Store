# ========================================
# 🗄️ DATABASE (PostgreSQL / Neon)
# ========================================
# Local Docker / Postgres:
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_NAME=TechnicalStore
DB_SSL=false
DB_SYNCHRONIZE=true


# Thời gian OTP còn hiệu lực (phút) — mặc định 10
OTP_EXPIRY_MINUTES=10

# ========================================
# 🚀 SERVER
# ========================================
PORT=3000
NODE_ENV=development

# ========================================
# 🔑 JWT
# ========================================
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# ========================================
# ☁️ CLOUDINARY (ảnh sản phẩm — Multer buffer → Cloudinary)
# ========================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=G4_TechnicalStore

# ========================================
# 🌐 FRONTEND
# ========================================
FRONTEND_URL=http://localhost:5173

# ========================================
# 💳 PAYOS
# ========================================
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key
PAYOS_RETURN_URL=http://localhost:5173/order-history?paymentSuccess=true
PAYOS_CANCEL_URL=http://localhost:5173/checkout?paymentCancelled=true

# ========================================
# ✉️ EMAIL (Nodemailer — OTP & xác nhận đơn hàng) — BẮT BUỘC để nhận OTP qua email
# ========================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM="G4 Technical Store" <your_email@gmail.com>
# EMAIL_TLS_REJECT_UNAUTHORIZED=false

# ========================================
# 🌱 SEED (npm run seed — xóa DB + nạp lại từ seed-data/)
# ========================================
# Mật khẩu ghi đè khi seed (ưu tiên hơn accounts.json nếu set)
SEED_DEFAULT_PASSWORD=G4@123456
SEED_ADMIN_PASSWORD=Admin@123
SEED_CUSTOMER_PASSWORD=Customer@123
# ========================================
# 🔐 GOOGLE OAUTH 2.0
# ========================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/account/auth/google/callback
